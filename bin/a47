#!/bin/bash
set -euo pipefail

ENTRY_SOURCE="${BASH_SOURCE[0]}"
REAL_SOURCE="$ENTRY_SOURCE"
while [ -h "$REAL_SOURCE" ]; do
  ENTRY_DIR="${REAL_SOURCE%/*}"
  if [ "$ENTRY_DIR" = "$REAL_SOURCE" ]; then
    ENTRY_DIR="."
  fi
  ENTRY_DIR="$(cd -P "$ENTRY_DIR" && pwd)"
  REAL_SOURCE="$(readlink "$REAL_SOURCE")"
  [[ $REAL_SOURCE != /* ]] && REAL_SOURCE="$ENTRY_DIR/$REAL_SOURCE"
done

ENTRY_DIR="${REAL_SOURCE%/*}"
if [ "$ENTRY_DIR" = "$REAL_SOURCE" ]; then
  ENTRY_DIR="."
fi
ENTRY_DIR="$(cd -P "$ENTRY_DIR" && pwd)"
RUNTIME_ENV_LIB="$ENTRY_DIR/../scripts/lib/runtime-env.sh"

if [ ! -f "$RUNTIME_ENV_LIB" ]; then
  echo "[ERR] Missing library: $RUNTIME_ENV_LIB"
  exit 1
fi

# shellcheck disable=SC1090
source "$RUNTIME_ENV_LIB"
init_agent47_runtime_from_entrypoint "$ENTRY_SOURCE"
load_agent47_libs constants.sh managed-files.sh common.sh update.sh templates.sh install-assets.sh install-runtime.sh install.sh doctor.sh

# ---------------------------
# Help
# ---------------------------
print_help() {
  echo "a47 - Agent & SDD CLI"
  echo "Version: $AGENT47_VERSION"
  echo ""
  echo "Core commands:"
  echo "  a47 help"
  echo "  a47 uninstall"
  echo "  a47 doctor [--check-update|--check-update-force]"
  echo ""
  echo "Project commands:"
  echo "  a47 add-agent                 bootstrap project scaffolding"
  echo "  a47 add-agent --force         refresh managed scaffolding"
  echo "  a47 add-agent --only-skills   install only skills"
  echo "  a47 add-agent --only-skills --force"
  echo "                               refresh only skills"
  echo "  a47 add-agent-prompt [--force]"
  echo "  a47 add-snapshot-prompt"
}

# ---------------------------
# Init Agent (project)
# ---------------------------
init_agent() {
  echo "[*] Initializing AGENT setup in current directory..."

  if [ ! -w "." ]; then
    echo "[ERR] Current directory is not writable"
    exit 1
  fi

  run_cmd add-agent
  echo "[OK] AGENT initialized"
}


# ---------------------------
# Command router
# ---------------------------
case "${1:-}" in
  help|"")
    print_help
    ;;
  uninstall)
    uninstall
    ;;
  doctor)
    doctor "${@:2}"
    ;;
  add-agent)
    run_cmd add-agent "${@:2}"
  ;;
  add-agent-prompt)
    run_cmd add-agent-prompt "${@:2}"
  ;;
  add-snapshot-prompt)
    run_cmd add-snapshot-prompt "${@:2}"
  ;;
  init-agent)
    init_agent
  ;;
  *)
    echo "Unknown command: ${1:-}"
    print_help
    exit 1
    ;;
esac
