#!/bin/bash
set -euo pipefail

AGENT47_HOME="${AGENT47_HOME:-$HOME/.agent47}"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
TEMPLATES_DIR="$AGENT47_HOME/templates"
RULES_TEMPLATES_DIR="$TEMPLATES_DIR/rules"
CONSTANTS_FILE="$AGENT47_HOME/scripts/lib/constants.sh"

RULES_DIR="rules"
FORCE=false
ONLY_SKILLS=false
TXN_WORK_DIR=""
TXN_STAGE_DIR=""
TXN_BACKUP_DIR=""
TXN_SUCCESS=false
TXN_CREATED_README=false
TXN_REPLACED_AGENTS=false
TXN_REPLACED_SKILLS=false
TXN_RULES_WRITTEN=()

if [ -f "$CONSTANTS_FILE" ]; then
  # shellcheck disable=SC1090
  source "$CONSTANTS_FILE"
  FILES=("${ALL_RULE_TEMPLATE_FILES[@]}")
else
  FILES=(
    "rules-mobile.yaml"
    "rules-frontend.yaml"
    "rules-backend.yaml"
    "security-global.yaml"
    "security-js-ts.yaml"
    "security-py.yaml"
    "security-java-kotlin.yaml"
    "security-swift.yaml"
    "security-csharp.yaml"
  )
fi

cleanup_transaction() {
  if [ -n "$TXN_WORK_DIR" ] && [ -d "$TXN_WORK_DIR" ]; then
    rm -rf "$TXN_WORK_DIR"
  fi
}

rollback_transaction() {
  local file

  if [ "$TXN_SUCCESS" = true ]; then
    return 0
  fi

  if [ "$TXN_CREATED_README" = true ]; then
    rm -f "README.md"
  fi

  if [ "$TXN_REPLACED_AGENTS" = true ]; then
    if [ -f "$TXN_BACKUP_DIR/AGENTS.md" ]; then
      mv "$TXN_BACKUP_DIR/AGENTS.md" "./AGENTS.md"
    else
      rm -f "./AGENTS.md"
    fi
  fi

  if [ "$TXN_REPLACED_SKILLS" = true ]; then
    rm -rf "skills"
    if [ -d "$TXN_BACKUP_DIR/skills" ]; then
      mv "$TXN_BACKUP_DIR/skills" "skills"
    fi
  fi

  for file in "${TXN_RULES_WRITTEN[@]}"; do
    if [ -f "$TXN_BACKUP_DIR/rules/$file" ]; then
      mv "$TXN_BACKUP_DIR/rules/$file" "$RULES_DIR/$file"
    else
      rm -f "$RULES_DIR/$file"
    fi
  done

  if [ -d "$RULES_DIR" ]; then
    rmdir "$RULES_DIR" >/dev/null 2>&1 || true
  fi
}

finish_transaction() {
  TXN_SUCCESS=true
  trap - EXIT INT TERM
  cleanup_transaction
}

setup_skills_stage() {
  local skills_dir="$1"
  local templates_dir="$AGENT47_HOME/templates/skills"
  local src dest_tmp dest_existing skill
  local skill_list=()

  echo "[INFO] Initializing agent skills..."
  mkdir -p "$skills_dir"

  while IFS= read -r skill; do
    [ -n "$skill" ] || continue
    skill_list+=("$skill")
  done < <(
    find "$templates_dir" -mindepth 2 -maxdepth 2 -type f -name 'SKILL.md' -print |
      while IFS= read -r path; do
        path="${path%/SKILL.md}"
        printf '%s\n' "${path##*/}"
      done | sort
  )

  if [ "$FORCE" != "true" ] && [ -d "skills" ]; then
    cp -R "skills/." "$skills_dir/"
  fi

  if [ "${#skill_list[@]}" -eq 0 ]; then
    echo "[ERR] No valid skill templates found in $templates_dir"
    return 1
  fi

  for skill in "${skill_list[@]}"; do
    src="$templates_dir/$skill"
    dest_tmp="$skills_dir/$skill"
    dest_existing="skills/$skill"

    if [ ! -d "$src" ]; then
      echo "[WARN] Template not found: $skill (skipping)"
      continue
    fi

    rm -rf "$dest_tmp"
    mkdir -p "$dest_tmp"

    if [ -d "$dest_existing" ] && [ "$FORCE" != "true" ]; then
      cp -R "$dest_existing/." "$dest_tmp/"
    else
      cp -R "$src/." "$dest_tmp/"
    fi

    if [ ! -f "$dest_tmp/SKILL.md" ]; then
      cp "$src/SKILL.md" "$dest_tmp/SKILL.md"
    fi

    if ! validate_skill "$dest_tmp/SKILL.md"; then
      if [ "$FORCE" = "true" ]; then
        echo "[ERR] Invalid skill template: $skill"
        return 1
      else
        echo "[WARN] Invalid SKILL.md for $skill; preserving existing content"
      fi
    fi
  done

  write_available_skills "$skills_dir" "$skills_dir/AVAILABLE_SKILLS.xml"
  echo "[OK] Skills setup complete."
}

prepare_transaction() {
  TXN_WORK_DIR="$(mktemp -d "${TMPDIR:-/tmp}/a47-stage-XXXXXX")"
  TXN_STAGE_DIR="$TXN_WORK_DIR/stage"
  TXN_BACKUP_DIR="$TXN_WORK_DIR/backup"
  mkdir -p "$TXN_STAGE_DIR" "$TXN_BACKUP_DIR"
  trap 'rollback_transaction; cleanup_transaction' EXIT INT TERM
}

stage_managed_files() {
  local file

  setup_skills_stage "$TXN_STAGE_DIR/skills"

  if [ "$ONLY_SKILLS" = "true" ]; then
    return 0
  fi

  mkdir -p "$TXN_STAGE_DIR/$RULES_DIR"
  for file in "${FILES[@]}"; do
    cp "$RULES_TEMPLATES_DIR/$file" "$TXN_STAGE_DIR/$RULES_DIR/$file"
  done

  cp "$TEMPLATES_DIR/AGENTS.md" "$TXN_STAGE_DIR/AGENTS.md"
}

commit_skills() {
  if [ -d "skills" ]; then
    mv "skills" "$TXN_BACKUP_DIR/skills"
  fi
  mv "$TXN_STAGE_DIR/skills" "skills"
  TXN_REPLACED_SKILLS=true
}

commit_rules() {
  local file target_path

  if [ ! -d "$RULES_DIR" ]; then
    mkdir "$RULES_DIR"
    echo "[OK] Created directory: $RULES_DIR/"
  fi

  mkdir -p "$TXN_BACKUP_DIR/rules"
  for file in "${FILES[@]}"; do
    target_path="$RULES_DIR/$file"
    if [ -f "$target_path" ]; then
      if [ "$FORCE" = true ]; then
        cp "$target_path" "$TXN_BACKUP_DIR/rules/$file"
        mv "$TXN_STAGE_DIR/$RULES_DIR/$file" "$target_path"
        TXN_RULES_WRITTEN+=("$file")
        echo "[OK] Updated: $target_path"
      else
        rm -f "$TXN_STAGE_DIR/$RULES_DIR/$file"
        echo "[WARN] $target_path already exists, skipping"
      fi
    else
      mv "$TXN_STAGE_DIR/$RULES_DIR/$file" "$target_path"
      TXN_RULES_WRITTEN+=("$file")
      echo "[OK] Copied: $target_path"
    fi
  done
}

commit_agents_file() {
  if [ -f "./AGENTS.md" ]; then
    if [ "$FORCE" = true ]; then
      mv "./AGENTS.md" "$TXN_BACKUP_DIR/AGENTS.md"
      mv "$TXN_STAGE_DIR/AGENTS.md" "./AGENTS.md"
      TXN_REPLACED_AGENTS=true
      echo "[OK] Updated: AGENTS.md"
    else
      rm -f "$TXN_STAGE_DIR/AGENTS.md"
      echo "[WARN] AGENTS.md already exists, skipping"
    fi
  else
    mv "$TXN_STAGE_DIR/AGENTS.md" "./AGENTS.md"
    TXN_REPLACED_AGENTS=true
    echo "[OK] Copied: AGENTS.md"
  fi
}

commit_readme() {
  if [ ! -f "README.md" ]; then
    touch "README.md"
    TXN_CREATED_README=true
    echo "[OK] README.md created"
  fi
}

usage() {
  echo "Usage: add-agent [--force] [--only-skills]"
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --force)
      FORCE=true
      shift
      ;;
    --only-skills)
      ONLY_SKILLS=true
      shift
      ;;
    *)
      usage
      exit 1
      ;;
  esac
done

echo "[INFO] Initializing agent environment..."

if [ ! -w "." ]; then
  echo "[ERR] Current directory is not writable"
  exit 1
fi

missing=0
if [ "$ONLY_SKILLS" != "true" ] && [ ! -f "$TEMPLATES_DIR/AGENTS.md" ]; then
  echo "[ERR] Template not found: AGENTS.md"
  missing=1
fi
if [ "$ONLY_SKILLS" != "true" ]; then
  for file in "${FILES[@]}"; do
    if [ ! -f "$RULES_TEMPLATES_DIR/$file" ]; then
      echo "[ERR] Template not found: $file"
      missing=1
    fi
  done
fi
if [ "$missing" -ne 0 ]; then
  echo "[ERR] Aborting: required templates missing."
  exit 1
fi

if [ ! -f "$AGENT47_HOME/scripts/skill-utils.sh" ]; then
  echo "[ERR] Aborting: missing helper dependency: $AGENT47_HOME/scripts/skill-utils.sh"
  exit 1
fi

if [ ! -d "$AGENT47_HOME/templates/skills" ]; then
  echo "[ERR] Aborting: missing skills templates: $AGENT47_HOME/templates/skills"
  exit 1
fi

# shellcheck disable=SC1090
source "$AGENT47_HOME/scripts/skill-utils.sh"

prepare_transaction
stage_managed_files

if [ "$ONLY_SKILLS" = "true" ]; then
  commit_skills
  finish_transaction
  echo "[OK] Agent skills ready"
  exit 0
fi

commit_rules
commit_agents_file
commit_readme
commit_skills
finish_transaction

echo "[OK] Agent environment ready"
