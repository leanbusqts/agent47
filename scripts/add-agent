#!/bin/bash
set -euo pipefail

AGENT47_HOME="${AGENT47_HOME:-$HOME/.agent47}"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
LOCAL_LIB_DIR="$SCRIPT_DIR/lib"
TEMPLATES_DIR="$AGENT47_HOME/templates"
# Shared path constant for sourced bootstrap modules.
# shellcheck disable=SC2034
RULES_TEMPLATES_DIR="$TEMPLATES_DIR/rules"
CONSTANTS_FILE="$LOCAL_LIB_DIR/constants.sh"
MANAGED_FILES_LIB="$LOCAL_LIB_DIR/managed-files.sh"
BOOTSTRAP_LIB="$LOCAL_LIB_DIR/bootstrap.sh"
AGENT47_SKILL_UTILS="$AGENT47_HOME/scripts/lib/skill-utils.sh"

if [ ! -f "$CONSTANTS_FILE" ]; then
  CONSTANTS_FILE="$AGENT47_HOME/scripts/lib/constants.sh"
fi
if [ ! -f "$MANAGED_FILES_LIB" ]; then
  MANAGED_FILES_LIB="$AGENT47_HOME/scripts/lib/managed-files.sh"
fi
if [ ! -f "$BOOTSTRAP_LIB" ]; then
  BOOTSTRAP_LIB="$AGENT47_HOME/scripts/lib/bootstrap.sh"
fi
if [ ! -f "$AGENT47_SKILL_UTILS" ]; then
  AGENT47_SKILL_UTILS="$LOCAL_LIB_DIR/skill-utils.sh"
fi

# shellcheck disable=SC1090
source "$CONSTANTS_FILE"
# shellcheck disable=SC1090
source "$MANAGED_FILES_LIB"
# shellcheck disable=SC1090
source "$BOOTSTRAP_LIB"

while [[ $# -gt 0 ]]; do
  case "$1" in
    --force)
      # Updated here for sourced bootstrap functions.
      # shellcheck disable=SC2034
      BOOTSTRAP_FORCE=true
      shift
      ;;
    --only-skills)
      BOOTSTRAP_ONLY_SKILLS=true
      shift
      ;;
    *)
      bootstrap_usage
      exit 1
      ;;
  esac
done

echo "[INFO] Initializing agent environment..."

if [ ! -w "." ]; then
  echo "[ERR] Current directory is not writable"
  exit 1
fi

bootstrap_require_templates
bootstrap_require_skills_support

# shellcheck disable=SC1090
source "$AGENT47_SKILL_UTILS"

bootstrap_prepare_transaction
bootstrap_stage_project_files

if [ "$BOOTSTRAP_ONLY_SKILLS" = "true" ]; then
  bootstrap_commit_skills
  bootstrap_finish_transaction
  echo "[OK] Agent skills ready"
  exit 0
fi

bootstrap_commit_rules
bootstrap_commit_agents_file
bootstrap_commit_readme
bootstrap_commit_skills
bootstrap_finish_transaction

echo "[OK] Agent environment ready"
