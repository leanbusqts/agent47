#!/bin/bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

if ! command -v shellcheck >/dev/null 2>&1; then
  echo "[ERR] shellcheck not found in PATH"
  echo "      Install shellcheck to lint the Bash sources in this repo."
  exit 1
fi

SHELL_FILES=()
while IFS= read -r file; do
  [ -n "$file" ] || continue
  SHELL_FILES+=("$file")
done < <(
  {
    [ -d "$ROOT_DIR/bin" ] && find "$ROOT_DIR/bin" -type f \( -name '*.sh' -o -perm -u+x \)
    [ -d "$ROOT_DIR/scripts" ] && find "$ROOT_DIR/scripts" -type f \( -name '*.sh' -o -perm -u+x \)
    [ -d "$ROOT_DIR/tests/helpers" ] && find "$ROOT_DIR/tests/helpers" -type f -name '*.bash'
    [ -d "$ROOT_DIR/tests/unit" ] && find "$ROOT_DIR/tests/unit" -type f -name '*.bats'
    [ -f "$ROOT_DIR/install.sh" ] && printf '%s\n' "$ROOT_DIR/install.sh"
  } | sort -u
)

if [ "${#SHELL_FILES[@]}" -eq 0 ]; then
  echo "[WARN] No shell files found"
  exit 0
fi

shellcheck "${SHELL_FILES[@]}"
