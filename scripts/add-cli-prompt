#!/bin/bash
set -euo pipefail

AGENT47_HOME="${AGENT47_HOME:-$HOME/.agent47}"
PROMPT_FILE="$AGENT47_HOME/templates/prompts/cli-prompt.txt"

if [ ! -f "$PROMPT_FILE" ]; then
  echo "[ERR] Template not found: cli-prompt.txt"
  exit 1
fi

content="$(cat "$PROMPT_FILE")"

if command -v pbcopy >/dev/null 2>&1; then
  if printf "%s" "$content" | pbcopy 2>/dev/null; then
    echo "[OK] CLI prompt copied to clipboard"
    exit 0
  fi
fi

printf "%s\n" "$content"
