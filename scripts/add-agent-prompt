#!/bin/bash
set -euo pipefail

AGENT47_HOME="${AGENT47_HOME:-$HOME/.agent47}"
TEMPLATE_FILE="$AGENT47_HOME/templates/prompts/agent-prompt.txt"
PROMPTS_DIR="prompts"
TARGET_FILE="$PROMPTS_DIR/agent-prompt.txt"
FORCE=false
while [ "$#" -gt 0 ]; do
  case "$1" in
    --force)
      FORCE=true
      shift
      ;;
    *)
      echo "Usage: add-agent-prompt [--force]"
      exit 1
      ;;
  esac
done

echo "[INFO] Initializing agent prompt..."

if [ ! -f "$TEMPLATE_FILE" ]; then
  echo "[ERR] Template not found: agent-prompt.txt"
  exit 1
fi

if [ ! -d "$PROMPTS_DIR" ]; then
  mkdir "$PROMPTS_DIR"
  echo "[OK] Created directory: $PROMPTS_DIR/"
fi

if [ -f "$TARGET_FILE" ]; then
  if [ "$FORCE" = true ]; then
    tmp_file="$(mktemp "$PROMPTS_DIR/.agent-prompt.tmp.XXXXXX")"
    cp "$TEMPLATE_FILE" "$tmp_file"
    mv -f "$tmp_file" "$TARGET_FILE"
    echo "[OK] Updated prompt: $TARGET_FILE"
    echo "[OK] Agent prompt setup complete."
    exit 0
  fi
  echo "[WARN] $TARGET_FILE already exists, skipping"
  exit 0
fi

tmp_file="$(mktemp "$PROMPTS_DIR/.agent-prompt.tmp.XXXXXX")"
cp "$TEMPLATE_FILE" "$tmp_file"
mv -f "$tmp_file" "$TARGET_FILE"
echo "[OK] Created prompt: $TARGET_FILE"
echo "[OK] Agent prompt setup complete."
