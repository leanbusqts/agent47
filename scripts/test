#!/bin/bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
TEST_RUNTIME_LIB="$ROOT_DIR/scripts/lib/test-runtime.sh"

# shellcheck disable=SC1090
source "$TEST_RUNTIME_LIB"

init_test_runtime
trap cleanup_test_runtime EXIT INT TERM
stage_test_environment
resolve_bats_bin
run_test_suite "$@"
